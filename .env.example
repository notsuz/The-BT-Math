# Copy this file to .env and fill in real values.
# Never commit the real .env file - it's already in .gitignore.

# --- Core --------------------------------------------------------------
# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
SITE_NAME=The BT Math
SITE_URL=http://127.0.0.1:8000

# --- Database (PostgreSQL) ----------------------------------------------
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Leave unset to fall back to a local sqlite db.sqlite3 (fine for a quick
# first run, but the requirements call for Postgres in production).
DATABASE_URL=postgres://btmath_user:changeme@localhost:5432/btmath

# --- Email (used for password reset emails) -----------------------------
# Defaults to printing emails to the console if left unset - fine for local
# dev. To actually send email (e.g. via Gmail SMTP with an App Password):
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@thebtmath.local

# --- eSewa (sandbox/UAT) -------------------------------------------------
# The values below are eSewa's own publicly documented RC/sandbox test
# merchant credentials - fine to use as-is while testing. Swap for your
# real merchant code + secret key once you get production access.
ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_PAYMENT_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
ESEWA_STATUS_CHECK_URL=https://rc.esewa.com.np/api/epay/transaction/status/

# --- Khalti (sandbox/test) -----------------------------------------------
# Sign up at https://test-admin.khalti.com/ to get your own test secret key
# (Khalti does not publish a shared one). Leave the URLs as-is for sandbox.
KHALTI_SECRET_KEY=
KHALTI_INITIATE_URL=https://dev.khalti.com/api/v2/epayment/initiate/
KHALTI_LOOKUP_URL=https://dev.khalti.com/api/v2/epayment/lookup/

# --- CSRF (only needed once you deploy behind a real domain/HTTPS) -------
CSRF_TRUSTED_ORIGINS=
